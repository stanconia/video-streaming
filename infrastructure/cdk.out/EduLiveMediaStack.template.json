  "IvsEventHandler9A932C5A": {
   "Type": "AWS::Lambda::Function",
   "Properties": {
    "Code": {
     "ZipFile": "\nconst { DynamoDBClient, UpdateItemCommand } = require('@aws-sdk/client-dynamodb');\n\nconst client = new DynamoDBClient({});\n\nexports.handler = async (event) => {\n  console.log('IVS Event:', JSON.stringify(event, null, 2));\n\n  const detail = event.detail;\n  const eventName = detail.event_name;\n  const channelArn = detail.channel_arn;\n\n  // Extract channel ID from ARN\n  const channelId = channelArn.split('/').pop();\n\n  let status;\n  switch (eventName) {\n    case 'Stream Start':\n      status = 'LIVE';\n      break;\n    case 'Stream End':\n      status = 'ENDED';\n      break;\n    case 'Recording Start':\n      status = 'RECORDING';\n      break;\n    case 'Recording End':\n      status = 'RECORDED';\n      break;\n    default:\n      console.log('Unhandled event:', eventName);\n      return { statusCode: 200 };\n  }\n\n  try {\n    // Update channel status in DynamoDB\n    // Note: This is a simplified example. In production, you'd need to\n    // query for the session first and then update.\n    console.log('Would update channel', channelId, 'to status', status);\n\n    return { statusCode: 200, body: 'Event processed' };\n  } catch (error) {\n    console.error('Error processing event:', error);\n    throw error;\n  }\n};\n      "
    },
    "Environment": {
     "Variables": {
      "CHANNELS_TABLE": {
       "Ref": "ChannelsTable6C883730"
      },
      "RECORDINGS_BUCKET": {
       "Ref": "RecordingsBucketAA52F499"
      }
     }
    },
    "FunctionName": "EduLive-dev-ivs-event-handler",
    "Handler": "index.handler",
    "Role": {
     "Fn::GetAtt": [
      "IvsEventHandlerServiceRole99C19FC9",
      "Arn"
     ]
    },
    "Runtime": "nodejs20.x",
    "Tags": [
     {
      "Key": "Application",
      "Value": "EduLive"
     },
     {
      "Key": "Environment",
      "Value": "dev"
     },
     {
      "Key": "ManagedBy",
      "Value": "CDK"
     }
    ],
    "Timeout": 30
   },
   "DependsOn": [
    "IvsEventHandlerServiceRoleDefaultPolicy31EEC11B",
    "IvsEventHandlerServiceRole99C19FC9"
   ],
   "Metadata": {
