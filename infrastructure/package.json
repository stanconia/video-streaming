{
  "name": "edulive-infrastructure",
  "version": "1.0.0",
  "description": "AWS CDK Infrastructure for EduLive - Educational Live Streaming Platform",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "cdk": "cdk",
    "synth": "cdk synth",
    "deploy": "cdk deploy --all",
    "deploy:network": "cdk deploy EduLiveNetworkStack",
    "deploy:database": "cdk deploy EduLiveDatabaseStack",
    "deploy:backend": "cdk deploy EduLiveBackendStack",
    "deploy:media": "cdk deploy EduLiveMediaStack",
    "deploy:frontend": "cdk deploy EduLiveFrontendStack",
    "destroy": "cdk destroy --all",
    "diff": "cdk diff",
    "bootstrap": "cdk bootstrap"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.120.0",
    "constructs": "^10.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "aws-cdk": "^2.120.0"
  }
}
